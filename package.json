{
  "name": "smart-safe-ai",
  "version": "1.0.0",
  "description": "SmartSafe AI - PPE Detection System",
  "main": "src/smartsafe/api/smartsafe_saas_api.py",
  "scripts": {
    "backend": "powershell -Command \"cd backend; ./venv/Scripts/python -m src.smartsafe.api.smartsafe_saas_api\"",
    "frontend": "python -m http.server 8000 --directory frontend",
    "generate": "powershell -Command \"cd backend; ./venv/Scripts/python scripts/setup/generate_frontend_assets.py\"",
    "test": "powershell -Command \"cd backend; ./venv/Scripts/python test_sector_integration.py\"",
    "install:python": "powershell -Command \"cd backend; ./venv/Scripts/python -m pip install -r requirements.txt\"",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "author": "Yigit033",
  "license": "MIT"
}
